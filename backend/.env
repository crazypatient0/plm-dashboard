# PLM Connection
PLM_BASE_URL=https://piaplmp.piagad.com
PLM_USERNAME=li_d3
PLM_PASSWORD=Tan45,=1

# Scrape Intervals (minutes)
SCRAPE_INTERVAL_PARTS=1               # How often to scrape parts data
SCRAPE_INTERVAL_DOCUMENTS=1           # How often to scrape documents
SCRAPE_INTERVAL_MQ_ACS=1              # How often to scrape MQ/ACS data

# Notification Webhooks (optional - leave blank to disable)
TEAMS_WEBHOOK_URL=                    # Microsoft Teams incoming webhook URL
DINGTALK_WEBHOOK_URL=                 # DingTalk custom robot webhook URL

# Database
DATABASE_URL=sqlite+aiosqlite:///./plm_dashboard.db

# Logging
LOG_LEVEL=INFO                        # DEBUG, INFO, WARNING, ERROR, CRITICAL
RETENTION_DAYS=90                     # Days to retain scraped data

# AI Provider
AI_PROVIDER=ollama                    # ollama, openai, azure, etc.
AI_API_KEY=                           # API key for AI provider (not needed for ollama)
AI_MODEL=llama3                       # Model name for AI provider
AI_ENABLED=true                       # Enable/disable AI features